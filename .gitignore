# SSH keys (devcontainer)
.ssh/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
# ...and a .venv SYMLINK, not just a directory: a git worktree shares the main checkout's venv
# by symlinking it, and the trailing-slash forms above match directories only — so without this
# a worktree's symlink gets committed, and CI's `uv sync` then dies on "File exists".
.venv
.mypy_cache/
ENV/
*.egg-info/
dist/
build/
.coverage
.coverage.*
coverage.json
htmlcov/

# Docker volumes and data
postgres_data/
wazuh_api_configuration/
wazuh_etc/
wazuh_logs/
wazuh_queue/
wazuh_var_multigroups/
wazuh_integrations/
wazuh_active_response/
wazuh_agentless/
wazuh_wodles/
wazuh-indexer-data/
/wazuh_cluster/

# Datasets (can be large)
datasets/
*.evtx
*.pcap

# Logs
*.log
logs/

# Environment files with secrets
.env
*.env.bak
*.key
*.pem
*.crt

# Per-environment config (template is tracked, actual config is not)
defender/knowledge/environment/systems/wazuh/config.env

# IDE
.vscode/
.idea/
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
/.claude/worktrees/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Runtime investigation/triage runs (contain sensitive alert data)
**/runs/*
!**/runs/.gitkeep

# Defender learning-loop ephemeral state — never committed.
defender/learning/_pending/
defender/learning/_pending_leads/
defender/learning/_author.lock
defender/learning/author-queue/
defender/learning/learn-queue/
defender/learning/.author-drain.lock
defender/learning/runs/
defender/learning/eval/results/
defender/learning/eval/_tmp/

# Defender run transcripts — local artifacts, not committed.
defender/run-transcripts/

# Ephemeral scratch work happens in git worktrees under .claude/worktrees/,
# not at the repo root. Kept experiment writeups live in /experiments/ (tracked).
/.claude/worktrees/
/.worktrees/

# Long-lived defender v2 worktree (branch defender-v2-env, local-only — see CLAUDE.md)
/defender-v2-tree/
experiments/actor-author-discipline/runs/
experiments/actor-author-discipline/results/
experiments/actor-author-discipline/__pycache__/
experiments/actor-author-discipline/**/__pycache__/

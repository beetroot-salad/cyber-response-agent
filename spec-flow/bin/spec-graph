#!/bin/sh
# spec-graph — the mechanical half of the write-tests gate, as one bare command.
#
# Two things this wrapper exists to hide, both learned the hard way:
#
#   * `$CLAUDE_PLUGIN_ROOT` does NOT expand inside SKILL.md prose and is NOT exported into
#     the Bash tool's environment — a skill that spells the checks as
#     `"$CLAUDE_PLUGIN_ROOT"/scripts/...` sends the agent hunting for a path it cannot
#     resolve. A plugin's bin/ *is* on the Bash PATH, so the skill just says `spec-graph`,
#     and the wrapper finds its own plugin root from $0.
#
#   * The interpreter needs PyYAML, and a repo-relative venv path (`x/.venv/bin/python`) does
#     not exist inside a git worktree — which is exactly where write-tests mandates the work
#     happen. So the interpreter is discovered, not configured.
#
# Usage:  spec-graph binds     [graph.yaml ...]            [--config <path>]
#         spec-graph actors    [graph.yaml] [--base <ref>] [--config <path>]
#         spec-graph claims    [graph.yaml ...]            [--config <path>]
#         spec-graph gate      [graph.yaml ...] [--residue] [--config <path>]
#         spec-graph lint      [graph.yaml ...]            [--config <path>]
#         spec-graph frontiers [dir] [--resume]
#         spec-graph calls     [graph.yaml | suite-dir] [--target <mod> ...]
#         spec-graph nullstub  [graph.yaml | suite-dir] [--target <mod> ...] [--python <interp>]
#         spec-graph trace     {drivers [--base <ref>] | resource [<name> ...]}
#
# Override the interpreter with SPEC_GRAPH_PYTHON=<path> if discovery picks wrong.
# (nullstub runs pytest with the PROJECT's interpreter: --python or $SPEC_GRAPH_TEST_PYTHON.)

set -eu

self=$0
while [ -L "$self" ]; do
  link=$(readlink "$self")
  case $link in
    /*) self=$link ;;
    *) self=$(dirname "$self")/$link ;;
  esac
done
scripts=$(cd "$(dirname "$self")/../scripts/spec_graph" && pwd)

case "${1:-}" in
  binds) script=$scripts/check_binds.py ;;
  actors) script=$scripts/check_actors.py ;;
  claims) script=$scripts/check_claims.py ;;
  gate) script=$scripts/check_gate.py ;;
  lint) script=$scripts/check_lint.py ;;
  frontiers) script=$scripts/check_frontiers.py ;;
  calls) script=$scripts/check_calls.py ;;
  nullstub) script=$scripts/check_stub.py ;;
  trace) script=$scripts/trace.py ;;
  *)
    echo "usage: spec-graph {binds|actors|claims|gate|lint|frontiers|calls|nullstub|trace} ..." >&2
    exit 2
    ;;
esac
shift

has_yaml() { command -v "$1" >/dev/null 2>&1 && "$1" -c "import yaml" >/dev/null 2>&1; }

if [ -n "${SPEC_GRAPH_PYTHON:-}" ]; then
  exec "$SPEC_GRAPH_PYTHON" "$script" "$@"
elif has_yaml python3; then
  exec python3 "$script" "$@"
elif command -v uv >/dev/null 2>&1; then
  # --no-project: never adopt the project whose directory we happen to be standing in. Without it
  # `uv run` picks up the nearest pyproject.toml and resolves ITS dependencies first — so
  # `cd defender && spec-graph binds` dies on an unrelated dependency conflict, offline registry,
  # or stale lock. The gate must not be hostage to the tree it is checking.
  exec uv run --quiet --no-project --with pyyaml python "$script" "$@"
else
  echo "spec-graph: no interpreter with PyYAML found." >&2
  echo "  install uv, or run: SPEC_GRAPH_PYTHON=/path/to/python spec-graph ..." >&2
  exit 1
fi

<!--
  Wazuh Custom Rules for Falco Events
  Maps Falco security alerts to Wazuh rule IDs with appropriate severity

  Rule ID Range: 100001-100099
  Severity Mapping:
    - Falco Emergency/Alert/Critical → Wazuh Level 12-15 (High)
    - Falco Error/Warning → Wazuh Level 7-10 (Medium)
    - Falco Notice/Informational → Wazuh Level 3-6 (Low)
-->

<group name="falco,security,">

  <!-- Base Falco Event Detection -->
  <rule id="100000" level="3">
    <decoded_as>json</decoded_as>
    <field name="output">\.+</field>
    <field name="rule">\.+</field>
    <field name="priority">\.+</field>
    <description>Falco security event detected</description>
    <options>no_full_log</options>
  </rule>

  <!-- Terminal Shell in Container -->
  <rule id="100001" level="10">
    <if_sid>100000</if_sid>
    <field name="rule">Terminal shell in container</field>
    <description>Falco: Terminal shell spawned in container</description>
    <group>falco_process_anomaly,attack.execution,</group>
  </rule>

  <!-- Redirect STDOUT/STDIN to Network (reverse shell / C2 indicator) -->
  <rule id="100002" level="12">
    <if_sid>100000</if_sid>
    <field name="rule">Redirect STDOUT/STDIN to Network Connection in Container</field>
    <description>Falco: STDOUT/STDIN redirected to network connection (possible reverse shell)</description>
    <group>falco_reverse_shell,attack.execution,attack.command_and_control,</group>
  </rule>

  <!-- Read Sensitive File Untrusted -->
  <rule id="100006" level="11">
    <if_sid>100000</if_sid>
    <field name="rule">Read sensitive file untrusted</field>
    <description>Falco: Sensitive file read by untrusted process</description>
    <group>falco_credential_access,attack.credential_access,</group>
  </rule>

  <!-- Drop and Execute New Binary in Container -->
  <rule id="100007" level="12">
    <if_sid>100000</if_sid>
    <field name="rule">Drop and execute new binary in container</field>
    <description>Falco: New binary dropped and executed in container</description>
    <group>falco_execution,attack.execution,attack.defense_evasion,</group>
  </rule>

  <!-- Clear Log Activities -->
  <rule id="100008" level="10">
    <if_sid>100000</if_sid>
    <field name="rule">Clear Log Activities</field>
    <description>Falco: Log clearing activity detected (anti-forensics)</description>
    <group>falco_defense_evasion,attack.defense_evasion,</group>
  </rule>

  <!-- Packet Socket Created in Container -->
  <rule id="100009" level="9">
    <if_sid>100000</if_sid>
    <field name="rule">Packet socket created in container</field>
    <description>Falco: Raw packet socket created in container (possible sniffing/scanning)</description>
    <group>falco_recon,attack.discovery,</group>
  </rule>

  <!-- High Priority Falco Alert (Emergency/Alert/Critical) — catch-all fallback.
       Level 5 so specific rules (level 9+) always win when they match. -->
  <rule id="100020" level="5">
    <if_sid>100000</if_sid>
    <field name="priority">Emergency|Alert|Critical</field>
    <description>Falco: HIGH PRIORITY security event (unclassified)</description>
    <group>falco_high_priority,</group>
  </rule>

  <!-- Medium Priority Falco Alert (Error/Warning) — catch-all fallback.
       Level 4 so specific rules always win. -->
  <rule id="100021" level="4">
    <if_sid>100000</if_sid>
    <field name="priority">Error|Warning</field>
    <description>Falco: Medium priority security event (unclassified)</description>
    <group>falco_medium_priority,</group>
  </rule>

  <!-- Process Injection Detection -->
  <rule id="100030" level="13">
    <if_sid>100000</if_sid>
    <field name="rule">process injection</field>
    <description>Falco: Potential process injection attempt</description>
    <group>falco_injection,attack.defense_evasion,</group>
  </rule>

  <!-- Container Escape Attempt -->
  <rule id="100031" level="15">
    <if_sid>100000</if_sid>
    <field name="rule">container escape</field>
    <description>Falco: Container escape attempt detected</description>
    <group>falco_container_escape,attack.privilege_escalation,</group>
  </rule>

  <!-- Privilege Escalation -->
  <rule id="100032" level="12">
    <if_sid>100000</if_sid>
    <field name="rule">privilege escalation|setuid|setgid</field>
    <description>Falco: Privilege escalation attempt</description>
    <group>falco_privesc,attack.privilege_escalation,</group>
  </rule>

  <!-- Reverse Shell Detection -->
  <rule id="100033" level="14">
    <if_sid>100000</if_sid>
    <field name="rule">reverse shell|bind shell</field>
    <description>Falco: Reverse/bind shell connection detected</description>
    <group>falco_reverse_shell,attack.command_and_control,</group>
  </rule>

  <!-- Cryptocurrency Mining -->
  <rule id="100034" level="10">
    <if_sid>100000</if_sid>
    <field name="rule">crypto|mining</field>
    <description>Falco: Potential cryptocurrency mining activity</description>
    <group>falco_cryptomining,attack.impact,</group>
  </rule>

  <!-- SSH/Credential Access -->
  <rule id="100035" level="11">
    <if_sid>100000</if_sid>
    <field name="rule">ssh.*key|credential</field>
    <description>Falco: SSH key or credential access attempt</description>
    <group>falco_credential_theft,attack.credential_access,</group>
  </rule>

  <!-- Kernel Module Loading -->
  <rule id="100036" level="13">
    <if_sid>100000</if_sid>
    <field name="rule">kernel module|insmod|modprobe</field>
    <description>Falco: Kernel module loading detected</description>
    <group>falco_kernel_module,attack.persistence,</group>
  </rule>

  <!-- File Integrity - Critical Paths -->
  <rule id="100037" level="11">
    <if_sid>100000</if_sid>
    <field name="rule">/etc/passwd|/etc/shadow|/etc/sudoers</field>
    <description>Falco: Critical system file accessed or modified</description>
    <group>falco_integrity,attack.persistence,</group>
  </rule>

  <!-- Data Exfiltration Indicators -->
  <rule id="100038" level="12">
    <if_sid>100000</if_sid>
    <field name="rule">exfiltration|curl.*post|wget.*post</field>
    <description>Falco: Potential data exfiltration activity</description>
    <group>falco_exfiltration,attack.exfiltration,</group>
  </rule>

  <!-- Docker/Container Runtime Tampering -->
  <rule id="100039" level="14">
    <if_sid>100000</if_sid>
    <field name="rule">docker.*socket|containerd</field>
    <description>Falco: Docker/container runtime access detected</description>
    <group>falco_container_runtime,attack.execution,</group>
  </rule>

</group>

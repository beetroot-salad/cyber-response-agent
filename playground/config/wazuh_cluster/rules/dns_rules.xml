<!--
  Wazuh Custom Rules for DNS Events (via dnsmasq)
  Detects suspicious DNS query patterns for investigation.

  Rule ID Range: 100100-100199
  Severity Mapping:
    - Known DGA/C2 patterns â†’ Level 10-12 (High)
    - Suspicious TLD/encoding â†’ Level 8-9 (Medium)
    - Informational DNS events â†’ Level 3-4 (Low)

  These rules match against dnsmasq query events decoded by dns_decoder.xml.
  The decoded fields are: url (domain), srcip (query source), dns_query_type.
-->

<group name="dns,security,">

  <!-- Base DNS query event (informational, not alerted by default) -->
  <rule id="100100" level="3">
    <decoded_as>dnsmasq-query</decoded_as>
    <description>DNS query logged by dnsmasq</description>
    <options>no_full_log</options>
    <group>dns_query,</group>
  </rule>

  <!-- DNS reply: NXDOMAIN (domain does not exist) -->
  <rule id="100101" level="3">
    <decoded_as>dnsmasq-reply</decoded_as>
    <match>NXDOMAIN</match>
    <description>DNS query returned NXDOMAIN</description>
    <group>dns_nxdomain,</group>
  </rule>

  <!-- ============================================ -->
  <!-- Suspicious Domain Patterns                   -->
  <!-- ============================================ -->

  <!--
    High-entropy subdomain pattern (potential DGA or DNS tunneling).
    Matches domains with long random-looking subdomains:
    - 12+ alphanumeric chars followed by a dot (e.g., xk3j2aab8f9q.example.com)
    This is a simple heuristic; real DGA detection needs more sophistication.
  -->
  <rule id="100110" level="10">
    <if_sid>100100</if_sid>
    <field name="url">\w{12,}\.\w+\.\w+</field>
    <description>DNS query to domain with high-entropy subdomain (possible DGA/tunneling)</description>
    <group>dns_suspicious,dns_dga,attack.command_and_control,</group>
  </rule>

  <!--
    Query to recently-registered or suspicious TLDs commonly abused.
    Matches: .xyz, .top, .club, .buzz, .tk, .ml, .ga, .cf, .gq, .pw, .cc, .ws
  -->
  <rule id="100111" level="8">
    <if_sid>100100</if_sid>
    <field name="url">\.xyz$|\.top$|\.club$|\.buzz$|\.tk$|\.ml$|\.ga$|\.cf$|\.gq$|\.pw$|\.cc$|\.ws$</field>
    <description>DNS query to frequently-abused TLD</description>
    <group>dns_suspicious,dns_suspicious_tld,</group>
  </rule>

  <!--
    DNS TXT query â€” commonly used for DNS tunneling / C2 data exfiltration.
    Legitimate uses exist (SPF, DKIM), but TXT queries from endpoints are unusual.
  -->
  <rule id="100112" level="9">
    <if_sid>100100</if_sid>
    <field name="dns_query_type">TXT</field>
    <description>DNS TXT query from endpoint (possible DNS tunneling/C2)</description>
    <group>dns_suspicious,dns_tunneling,attack.command_and_control,</group>
  </rule>

  <!--
    Burst of NXDOMAIN replies â€” DGA malware typically generates many failed lookups
    as it iterates through algorithmically generated domains looking for the active C2.
    Frequency: 8+ NXDOMAIN replies in 120 seconds from same agent.
  -->
  <rule id="100113" level="10" frequency="8" timeframe="120">
    <if_matched_sid>100101</if_matched_sid>
    <same_source_ip />
    <description>Burst of NXDOMAIN responses (possible DGA activity)</description>
    <group>dns_suspicious,dns_dga,attack.command_and_control,</group>
  </rule>

  <!--
    Hexadecimal-encoded subdomain pattern â€” potential data exfiltration via DNS.
    Matches subdomains that look like hex-encoded data (16+ hex chars).
    Example: 4a6f686e446f65.exfil.attacker.com
  -->
  <rule id="100114" level="11">
    <if_sid>100100</if_sid>
    <field name="url">[0-9a-f]{16,}\.</field>
    <description>DNS query with hex-encoded subdomain (possible data exfiltration)</description>
    <group>dns_suspicious,dns_exfiltration,attack.exfiltration,</group>
  </rule>

  <!--
    Known C2/malware callback domain patterns used by our test workload.
    In production, this would be a CDB list lookup. For testing, we match
    specific patterns our workload generates.
  -->
  <rule id="100115" level="12">
    <if_sid>100100</if_sid>
    <field name="url">\.onion\.|malware-c2|callback\.evil|beacon\.\w+\.cc</field>
    <description>DNS query to known malicious domain pattern</description>
    <group>dns_suspicious,dns_c2,attack.command_and_control,</group>
  </rule>

  <!--
    High volume DNS queries â€” potential beaconing or tunneling.
    15+ queries in 60 seconds from same source.
  -->
  <rule id="100116" level="9" frequency="15" timeframe="60">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>High-volume DNS queries from single source (possible beaconing/tunneling)</description>
    <group>dns_suspicious,dns_beaconing,attack.command_and_control,</group>
  </rule>

  <!--
    Base64-like subdomain pattern â€” another exfiltration encoding.
    Matches subdomains with mixed case + digits + padding chars, 20+ chars.
  -->
  <rule id="100117" level="10">
    <if_sid>100100</if_sid>
    <field name="url">[A-Za-z0-9+/=]{20,}\.</field>
    <description>DNS query with base64-like subdomain (possible data exfiltration)</description>
    <group>dns_suspicious,dns_exfiltration,attack.exfiltration,</group>
  </rule>

</group>

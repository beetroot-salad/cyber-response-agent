# Copy to .env (gitignored) and fill in / override.

STACK_VERSION=9.3.3
CLUSTER_NAME=soc-playground

# Keycloak pin. Probe availability before bumping:
#   docker --context soc-playground manifest inspect quay.io/keycloak/keycloak:<tag>
KEYCLOAK_VERSION=26.1

# Namespaced to avoid collision with v1 vars in /workspace/.env.
# Generate with: openssl rand -base64 32 | tr -d '=+/' | cut -c1-32
V2_ELASTIC_PASSWORD=changeme
V2_KIBANA_PASSWORD=changeme

# Kibana encryption key — >= 32 chars. Used for saved-objects and reporting encryption.
# Generate with: openssl rand -base64 48 | tr -d '=+/' | cut -c1-48
V2_KIBANA_ENCRYPTION_KEY=changeme-changeme-changeme-changeme

# Keycloak bootstrap admin (master realm). Used once on first boot; after that
# manage via Keycloak UI → Users (create long-lived admin, disable this one).
V2_KEYCLOAK_ADMIN=admin
V2_KEYCLOAK_ADMIN_PASSWORD=changeme

# ES JVM heap (50% of container mem_limit, <=31g).
ES_HEAP=2g

# Case-history store configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/case_history/ticket_writer.py (the run.py/run_pai.py
# --update-ticket post-step). No credentials — the stub is auth-less on the
# compose network and reached via `docker --context soc-playground exec`.
#
# Deliberately SEPARATE from systems/ticket/config.env (the read-side gather
# adapter) even though both point at the same ticket-server today: the
# case-history store the learning loop accrues is conceptually distinct from
# the customer ticketing SoR the defender reads during an investigation. The
# split keeps that decoupling explicit so it survives a real deployment.

CASE_HISTORY_URL_BASE="http://ticket-server:8080"
CASE_HISTORY_BASTION_HOST="web-1"
CASE_HISTORY_TIMEOUT_SEC="10"

# CMDB stub deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/cmdb_adapter.py. No credentials — stubs are auth-less
# on the compose network and are reached via `docker --context soc-playground exec`.

# Compose-internal URL. The defender does not curl this directly from the
# devcontainer; cmdb_adapter.py routes via docker-exec against BASTION_HOST.
CMDB_URL_BASE="http://cmdb:8080"

# Any host on the compose network reaches every stub via Docker DNS.
# web-1 is the bastion of convenience — pick a different role host if
# web-1 is being recreated during ops.
CMDB_BASTION_HOST="web-1"

# Per-call timeout passed to curl --max-time inside the bastion.
CMDB_TIMEOUT_SEC="10"

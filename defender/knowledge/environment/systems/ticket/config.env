# Ticket-server stub deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/ticket_adapter.py. No credentials — stub is
# auth-less on the compose network and reached via `docker --context
# soc-playground exec`. The underlying app is shared with v1; this adapter
# uses the v2 docker-exec transport instead of v1's direct HTTP.

TICKET_URL_BASE="http://ticket-server:8080"
TICKET_BASTION_HOST="web-1"
TICKET_TIMEOUT_SEC="10"

# The key grammar of THIS store, as an unanchored regex (consumers anchor it). Every key
# here is minted by defender/scripts/case_history/ticket_writer.py as the case id — the run
# dir basename, `{%Y%m%dT%H%M%SZ}-{alert_label}` — and the seeded cases use `SOC-<n>`.
#
# It is REQUIRED, and consumers that screen on it must fail closed and loud when it is
# absent: it is what the benign judge's get_closed_ticket screens a model-chosen key against
# before any store attempt (#672 Fork A / #684). A missing value must stop the read, never
# fall back to a built-in guess about what this store's keys look like. Swapping this
# environment for a store with another key vocabulary (Jira `ABC-123`, ServiceNow sys_ids)
# means editing this line — not the judge's code.
TICKET_KEY_PATTERN="[A-Za-z0-9][A-Za-z0-9._-]*"

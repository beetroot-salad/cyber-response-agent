# Identity stub deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/identity_cli.py. No credentials — stubs are
# auth-less on the compose network and are reached via `docker --context
# soc-playground exec`.

IDENTITY_URL_BASE="http://identity:8080"
IDENTITY_BASTION_HOST="web-1"
IDENTITY_TIMEOUT_SEC="10"

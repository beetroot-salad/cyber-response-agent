# Elastic Stack deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/elastic_cli.py. Non-secret values only.
# Credentials are NOT needed here: the adapter exec's curl inside the ES/Kibana
# container over the soc-playground docker context and uses the container's own
# ELASTIC_PASSWORD (mirrors infra/bin/es.sh).

# Service endpoints AS SEEN FROM INSIDE the stack containers. The adapter reaches
# ES/Kibana via `docker --context soc-playground exec <container> curl …`, so
# these are container-local URLs — no host-side SSH tunnel is required.
ELASTICSEARCH_URL="https://localhost:9200"
KIBANA_URL="http://localhost:5601"

# Default index patterns for the two surfaces the adapter exposes.
# Events: raw Elastic Agent / Filebeat / Falco streams (logs-*).
# Alerts: detection-engine signals from rules in playground-v2/detection-rules/.
ELASTIC_EVENTS_INDEX="logs-*"
ELASTIC_ALERTS_INDEX=".internal.alerts-security.alerts-default-*"

# Data retention floor — informational; affects how far back time windows may reach.
ELASTIC_RETENTION_DAYS="30"

# TLS verification — disabled for the self-signed playground cert.
ELASTIC_SSL_VERIFY="false"

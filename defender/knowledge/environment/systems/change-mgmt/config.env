# Change-mgmt stub deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/change_mgmt_adapter.py. No credentials — stubs
# are auth-less on the compose network and are reached via `docker --context
# soc-playground exec`.

CHANGE_MGMT_URL_BASE="http://change-mgmt:8080"
CHANGE_MGMT_BASTION_HOST="web-1"
CHANGE_MGMT_TIMEOUT_SEC="10"

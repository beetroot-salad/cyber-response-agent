# Threat-intel stub deployment configuration — playground-v2 (Hetzner VPS)
# Read by defender/scripts/adapters/threat_intel_adapter.py. No credentials — stubs
# are auth-less on the compose network and are reached via `docker --context
# soc-playground exec`.

THREAT_INTEL_URL_BASE="http://threat-intel:8080"
THREAT_INTEL_BASTION_HOST="web-1"
THREAT_INTEL_TIMEOUT_SEC="10"

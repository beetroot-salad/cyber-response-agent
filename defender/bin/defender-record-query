#!/usr/bin/env bash
# Auto-stable invocation shim for record_query.py. The agent calls `defender-record-query <args>`
# instead of a path/module form so the allowlist matches one stable token
# regardless of cwd, venv path, or compound wrapping. See defender/bin/README.md.
PY="${DEFENDER_DIR:?DEFENDER_DIR is not set}/.venv/bin/python3"
[ -x "$PY" ] || PY=python3
exec "$PY" "${DEFENDER_DIR}/scripts/gather_tools/record_query.py" "$@"

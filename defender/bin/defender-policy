#!/usr/bin/env bash
# Stable invocation shim for the gate's audit CLI (scripts/policy_cli.py):
#   defender-policy show <agent> --run-dir <dir>
#   defender-policy explain <agent> '<command>' --run-dir <dir> [--json]
# An OPERATOR tool, NOT an agent one: it is listed in hooks/_cmd_segments.OPERATOR_TOOLS, so it
# is neither a data-source adapter (which gather could run and capture) nor a granted shim — no
# agent's lane admits it. Reading your own gate is a map of what to attack.
DEFENDER="${DEFENDER_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
PY="${DEFENDER}/.venv/bin/python3"
[ -x "$PY" ] || PY=python3
cd "${DEFENDER}/.." || exit 1
exec "$PY" -m defender.scripts.policy_cli "$@"

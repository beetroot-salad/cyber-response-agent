#!/usr/bin/env bash
# Example invocation shim — copy to defender/bin/defender-{system}, swap the
# CLI filename, and `chmod +x`. The agent calls `defender-{system} <args>`
# so the harness allowlist matches one stable token regardless of cwd or
# venv path. Dropping this in bin/ auto-gates the adapter (see bin/README.md).
PY="${DEFENDER_DIR:?DEFENDER_DIR is not set}/.venv/bin/python3"
[ -x "$PY" ] || PY=python3
exec "$PY" "${DEFENDER_DIR}/scripts/tools/example_cli.py" "$@"

{
  "permissions": {
    "allow": [
      "Read(/workspace/defender/**)",
      "Read(/tmp/defender-runs/**)",
      "Grep(/workspace/defender/**)",
      "Grep(/tmp/defender-runs/**)",
      "Glob(/workspace/defender/**)",
      "Glob(/tmp/defender-runs/**)",
      "Write(/tmp/defender-runs/**)",
      "Edit(/tmp/defender-runs/**)",
      "Write(/workspace/defender/skills/gather/queries/*/_draft/**)",
      "Edit(/workspace/defender/skills/gather/queries/*/_draft/**)",
      "Write(/workspace/defender/skills/*/_draft/**)",
      "Edit(/workspace/defender/skills/*/_draft/**)",
      "Write(/workspace/defender-v2-tree/defender/skills/gather/queries/*/_draft/**)",
      "Edit(/workspace/defender-v2-tree/defender/skills/gather/queries/*/_draft/**)",
      "Write(/workspace/defender-v2-tree/defender/skills/*/_draft/**)",
      "Edit(/workspace/defender-v2-tree/defender/skills/*/_draft/**)",
      "Write(/workspace/.claude/worktrees/*/defender/skills/gather/queries/*/_draft/**)",
      "Edit(/workspace/.claude/worktrees/*/defender/skills/gather/queries/*/_draft/**)",
      "Write(/workspace/.claude/worktrees/*/defender/skills/*/_draft/**)",
      "Edit(/workspace/.claude/worktrees/*/defender/skills/*/_draft/**)",
      "Bash(defender-* *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Task(*)",
      "Skill(*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/credentials*)",
      "Read(**/.ssh/**)",
      "Read(/workspace/soc-agent/**)",
      "Read(**/ground_truth*)",
      "Read(**/ground-truth*)",
      "Read(**/cases.json)",
      "Grep(**/ground_truth*)",
      "Grep(**/ground-truth*)",
      "Glob(**/ground_truth*)",
      "Glob(**/ground-truth*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/record_lead.py"
          },
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/inject_system_skill_description.py"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/approve_shim_invocations.py"
          },
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/block_main_loop_raw_access.py"
          },
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/block_unwrapped_adapter_calls.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/invlang_validate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/budget_enforcer.py"
          }
        ]
      },
      {
        "matcher": "Task|Agent|Bash|Read|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/tag_tool_results.py"
          }
        ]
      }
    ]
  }
}

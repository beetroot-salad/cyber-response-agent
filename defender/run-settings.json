{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Grep(*)",
      "Glob(*)",
      "Task(*)",
      "Skill(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${PYTHON} ${DEFENDER_DIR}/hooks/extract_lead_metadata.py"
          }
        ]
      }
    ]
  }
}

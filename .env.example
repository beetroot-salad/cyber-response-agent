# Copy to .env and fill in values for your environment. .env is git-ignored.

# soc-agent runs directory — base path for all investigation run artifacts.
# eval_run.sh overrides this per-eval to a nested subdirectory; ad-hoc plugin
# invocations (setup_run.py, hooks, stub_ticket_cli) read this value directly.
# Consumers fail fast if unset — there is no default.
SOC_AGENT_RUNS_DIR=

# --- Optional tunables (defaults shown) -------------------------------------
# The following have working defaults in code; set only to override.

# Haiku judge model alias used by validate_conclude.py (pre-CONCLUDE gate,
# two parallel judges) and validate_report.py (post-report Tier 2 delta judge).
#SOC_AGENT_JUDGE_MODEL=haiku

# Shared wall-clock bound for a single judge invocation. Pre-CONCLUDE runs
# two judges in parallel behind this same deadline — total gate time is
# bounded by this value, not 2×.
#SOC_AGENT_JUDGE_TIMEOUT_SECONDS=120

# Wall-clock bound for Stop-stage act-mode tool invocations (close_ticket, ...).
#SOC_AGENT_ACTION_TIMEOUT_SECONDS=30

# Claude Code transcript path; normally injected by the harness, override
# only when testing hooks outside a live session.
#SOC_AGENT_TRANSCRIPT_PATH=

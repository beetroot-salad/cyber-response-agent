# Copy to .env and fill in values for your environment. .env is git-ignored.
#
# /workspace/.env is auto-exported into interactive shells (see
# .devcontainer/Dockerfile.dev). `docker compose` then resolves the ${VAR}
# interpolations in the stack files (wazuh-stack.yml, elastic-stack.yml,
# docker-compose.yml) from that shell environment, and the hcloud CLI reads
# HCLOUD_TOKEN directly. Per-machine compose settings (HOST_WORKSPACE, build-arg
# version pins) live in .devcontainer/.env — see .devcontainer/.env.example.

# --- Wazuh stack -------------------------------------------------------------
# API user/password back the wazuh-mcp-server and Wazuh manager API.
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=
WAZUH_INDEXER_PASSWORD=
WAZUH_DASHBOARD_PASSWORD=

# --- Elastic stack -----------------------------------------------------------
ELASTIC_PASSWORD=
KIBANA_SYSTEM_PASSWORD=
# Kibana saved-objects encryption key (>= 32 chars).
KIBANA_ENCRYPTION_KEY=

# --- Hetzner Cloud -----------------------------------------------------------
# API token for the hcloud CLI / terraform (v2 playground VPS provisioning).
HCLOUD_TOKEN=

# Copy to .env and fill in values for your environment. .env is git-ignored.

# soc-agent runs directory — base path for all investigation run artifacts.
# eval_run.sh overrides this per-eval to a nested subdirectory; ad-hoc plugin
# invocations (setup_run.py, hooks, stub_ticket_cli) read this value directly.
# Consumers fail fast if unset — there is no default.
SOC_AGENT_RUNS_DIR=

{
  "name": "soc-agent",
  "version": "3.4.0",
  "description": "Hypothesis-driven security alert triage agent. Investigates alerts through iterative hypothesis elimination, validates findings against precedents, and recommends disposition.",
  "author": {
    "name": "Cyber Response Agent"
  },
  "skills": "./skills/",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop_handler.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/inject_env_context.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/infer_state_pre.py"
          },
          {
            "type": "command",
            "if": "Edit(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/infer_state_pre.py"
          },
          {
            "type": "command",
            "if": "Write(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate_conclude.py"
          },
          {
            "type": "command",
            "if": "Edit(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate_conclude.py"
          },
          {
            "type": "command",
            "if": "Write(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/invlang_validate.py"
          },
          {
            "type": "command",
            "if": "Edit(*/investigation.md)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/invlang_validate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/extract_subagent_yaml.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/infer_state.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate_report.py"
          }
        ]
      },
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tag_tool_results.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "if": "Read(*/alert.json)",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/tag_tool_results.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/audit_tool_calls.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/budget_enforcer.py"
          }
        ]
      }
    ]
  }
}

# Playground ticket-server configuration
# Read by scripts/tools/playground_ticket_cli.py — non-secret values only.
# The playground ticket-server is auth-less, so there are no credentials.
#
# Copy this file to config.env and fill in your environment values:
#   cp config.env.template config.env

# Base URL for the playground ticket-server FastAPI stub.
# - From inside the dev compose network: http://ticket-server:8080
# - From the host shell:                  http://localhost:8080
PLAYGROUND_TICKET_BASE_URL="http://ticket-server:8080"

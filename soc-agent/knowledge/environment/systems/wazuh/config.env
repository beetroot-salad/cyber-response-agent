# Wazuh deployment configuration
# Read by scripts/siem/wazuh_cli.py — non-secret values only.
# Credentials come from environment variables or secrets manager.

# Index pattern for Wazuh alerts
WAZUH_INDEX="wazuh-alerts-*"

# Wazuh API endpoint (accessible from within Docker network)
WAZUH_API_ENDPOINT="https://wazuh-manager:55000"

# Data retention — how far back events exist (days)
WAZUH_RETENTION_DAYS="90"

# Wazuh deployment configuration
# Read by scripts/siem/wazuh_cli.py — non-secret values only.
# Credentials come from environment variables (WAZUH_INDEXER_USER,
# WAZUH_INDEXER_PASSWORD, WAZUH_API_USER, WAZUH_API_PASSWORD).
#
# Copy this file to config.env and fill in your environment values:
#   cp config.env.template config.env

# Index pattern for Wazuh alerts
WAZUH_INDEX="wazuh-alerts-*"

# Wazuh Manager API endpoint (agent management, health checks)
WAZUH_API_ENDPOINT="https://your-wazuh-manager:55000"

# Wazuh Indexer endpoint (OpenSearch — alert queries)
WAZUH_INDEXER_ENDPOINT="https://your-wazuh-indexer:9200"

# Data retention — how far back events exist (days)
WAZUH_RETENTION_DAYS="90"

# TLS verification (true/false). Set to true in production with a valid CA cert.
WAZUH_SSL_VERIFY="true"

# Path to CA certificate for TLS verification (required when WAZUH_SSL_VERIFY=true)
WAZUH_CA_CERT="/path/to/ca.pem"

# Elastic Stack deployment configuration
# Read by scripts/tools/elastic_cli.py — non-secret values only.
# Credentials come from environment variables (ELASTIC_USERNAME, ELASTIC_PASSWORD).
#
# Copy this file to config.env and fill in your environment values:
#   cp config.env.template config.env

# Elasticsearch base URL (no trailing slash). Raw search surface.
ELASTICSEARCH_URL="http://your-elasticsearch:9200"

# Kibana base URL. Used by health-check for status and by anything that needs
# the detection engine management APIs. Searches run directly against ES.
KIBANA_URL="http://your-kibana:5601"

# Default index pattern for `query` — raw event data streams.
# Narrow this if your deployment uses a non-standard data-stream layout
# (e.g. "logs-system.*,logs-endpoint.*").
ELASTIC_EVENTS_INDEX="logs-*"

# Index (or alias) for detection-engine signals read by `alerts`.
# Default covers the standard Elastic Security signals alias.
ELASTIC_ALERTS_INDEX=".alerts-security.alerts-default"

# TLS verification (true/false). Set to true in production with a valid CA cert.
ELASTIC_SSL_VERIFY="false"

# Path to CA certificate for TLS verification (required when ELASTIC_SSL_VERIFY=true).
ELASTIC_CA_CERT=""

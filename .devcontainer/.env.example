# Compose-time configuration for the playground stack.
#
# Copy this to .devcontainer/.env and fill in HOST_WORKSPACE with the host
# filesystem path that maps to /workspace inside the devcontainer. This
# enables `docker compose` to be invoked from inside the devcontainer (the
# docker daemon runs on the host and only speaks host paths).
#
# Find HOST_WORKSPACE with:
#   docker inspect response-devcontainer --format \
#     '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}'

# Default file list — lets you skip the -f flags on `docker compose` calls.
COMPOSE_FILE=docker-compose.yml:wazuh-stack.yml:wazuh-overrides.yml:elastic-stack.yml

# Per-user host path. Example for Docker Desktop on WSL2:
#   /run/desktop/mnt/host/c/Users/<you>/path/to/cyber-response-agent
HOST_WORKSPACE=

# Per-machine devcontainer build configuration.
#
# Copy this to .devcontainer/.env (gitignored) if you need to override the
# build-arg version pins below. The devcontainer otherwise needs no .env —
# it builds and runs from tracked defaults.

# Optional per-machine overrides for Dockerfile.dev build args. The compose
# file provides team-baseline defaults; uncomment + bump locally to run ahead
# of the tracked pin without producing a tracked diff. The committed baseline
# moves periodically in a batched bump PR.
# HCLOUD_VERSION=1.62.2
# CODEX_VERSION=0.137.0

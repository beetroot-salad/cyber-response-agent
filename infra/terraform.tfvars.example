# Copy to terraform.tfvars (gitignored) and fill in.

# Public key text — paste the contents of your ~/.ssh/id_ed25519.pub (or rsa).
# The matching private key stays on your machine; Terraform never sees it.
ssh_public_key = "ssh-ed25519 AAAA... user@host"

# Narrow this to the IP you actually SSH from. Detected public IP at writing: 147.235.201.26
ssh_source_cidrs = ["147.235.201.26/32"]

# Optional overrides:
# server_name = "soc-playground"
# server_type = "ccx33"
# location    = "fsn1"
# image       = "ubuntu-24.04"
